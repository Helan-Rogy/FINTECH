{
  "fraud_explanation_report_schema": {
    "description": "JSON schema for fraud prediction explanation reports",
    "example": {
      "prediction_id": "fraud_txn_00000001_1774626849.916222",
      "timestamp": "2026-03-27T21:24:09.916243",
      "subject_id": "txn_00000001",
      "model_type": "fraud",
      "score": 0.85,
      "band": "high",
      "confidence": 0.8825,
      "primary_reason_code": "FRD_GEO_MISMATCH",
      "supporting_reasons": [
        {
          "code": "FRD_VEL_HIGH",
          "severity": "MEDIUM",
          "explanation": "5 transactions in 24 hours (baseline: ~1-2 per day)",
          "metric_value": 5
        },
        {
          "code": "FRD_MERCHANT_NEW",
          "severity": "MEDIUM",
          "explanation": "First transaction with this merchant"
        }
      ],
      "human_summary": "Transaction FLAGGED as high fraud risk.\n\nKey concerns:\n- Geographic jump detected - significant location change in <4 hours (physically impossible travel)\n- 5 transactions in 24 hours (baseline: ~1-2 per day)\n- First transaction with this merchant",
      "suggested_actions": [
        "URGENT: Contact customer to verify transaction - impossible geographic location",
        "Verify rapid transaction pattern with customer",
        "Verify new merchant transaction"
      ]
    },
    "field_definitions": {
      "prediction_id": {
        "type": "string",
        "description": "Unique identifier for this prediction and explanation"
      },
      "timestamp": {
        "type": "string",
        "format": "ISO-8601",
        "description": "Time when explanation was generated"
      },
      "subject_id": {
        "type": "string",
        "description": "Transaction ID or entity identifier"
      },
      "model_type": {
        "type": "string",
        "enum": ["fraud", "risk"],
        "description": "Type of model that generated the prediction"
      },
      "score": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "description": "Raw prediction score (0-1)"
      },
      "band": {
        "type": "string",
        "enum": ["low", "medium", "high"],
        "description": "Categorical risk band"
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "description": "Model confidence in this prediction"
      },
      "primary_reason_code": {
        "type": "string",
        "description": "Most important reason code (highest severity)"
      },
      "supporting_reasons": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "Reason code identifier"
            },
            "severity": {
              "type": "string",
              "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"],
              "description": "Severity level of this reason"
            },
            "explanation": {
              "type": "string",
              "description": "Human-readable explanation of this reason"
            },
            "metric_value": {
              "type": "number",
              "description": "Optional: numerical value for context"
            }
          }
        },
        "description": "List of supporting reason codes (top 3)"
      },
      "human_summary": {
        "type": "string",
        "description": "Human-readable summary suitable for non-technical users"
      },
      "suggested_actions": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Recommended next steps (1-3 actions)"
      }
    }
  },
