# ──────────────────────────────────────────────
# FinTech AI Platform — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in values

# Neon PostgreSQL connection string (required)
# Provided automatically by the Neon integration on Vercel
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT signing secret — change this to a strong random string in production
# e.g. openssl rand -hex 32
JWT_SECRET=your-secret-key-change-in-production

# Node environment
NODE_ENV=development
